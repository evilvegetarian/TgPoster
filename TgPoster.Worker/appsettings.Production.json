{
  "TelegramOptions": {
    "SecretKey": ""
  },
  "DataBase": {
    "ConnectionString": ""
  },
  "TelegramSettings": {
    "api_id": "",
    "api_hash": "",
    "phone_number": ""
  },
  "TracingConfiguration": {
    "Url": "http://tg-jaeger:4318/v1/traces"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Hangfire.BackgroundJobServer": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Hangfire.Server.BackgroundServerProcess": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "restrictedToMinimumLevel": "Verbose",
          "propertiesAsLabels": [
            "Application",
            "Level"
          ]
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "worker"
    }
  }
}
